# 复制本文件为 railway_debug_pg.ini 后填写真实值
# railway_debug_pg.ini 已加入 .gitignore,不会被提交到 Git
#
# 🔗 Supabase 控制台:
#    Dashboard → Project Settings → Database → Connection parameters
#
# 📝 使用方法:
#    1. 复制此文件: Copy-Item railway_debug_pg.ini.example railway_debug_pg.ini
#    2. 填写下方的 host, user, password
#    3. 运行程序测试连接
#
# ⚠️ 注意:
#    - port=6543 使用 Pooler (推荐,支持高并发)
#    - port=5432 直连数据库 (连接数有限)
#    - sslmode=require 必须使用 SSL 加密连接

[postgres]
# 主机地址 (从 Supabase 获取)
host=db.xxxxx.supabase.co

# 端口 (Pooler: 6543, Direct: 5432)
port=6543

# 数据库名 (通常为 postgres)
database=postgres

# 用户名 (格式: postgres.项目ID)
user=postgres

# 密码 (从 Supabase 获取,如包含特殊字符请用引号)
password=

# SSL 模式 (require=强制加密, prefer=优先加密, disable=禁用)
sslmode=require
